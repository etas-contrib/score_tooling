@startuml class_diagram_relationship_variants

set namespaceSeparator ::

package sample::relationships {
    interface ParentContract
    interface WorkerContract

    class WorkerImpl

    struct WorkerResponse {
        + WorkerStatus
    }

    interface CheckFlag {
        + Get() : WorkerStatus
    }

    enum WorkerStatus

    ParentContract <|-- WorkerContract
    WorkerImpl ..|> WorkerContract
    WorkerResponse --> WorkerStatus
    WorkerResponse o- WorkerStatus
    WorkerImpl "1" *-- "0..*" WorkerStatus
}

@enduml
